    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"title\": \"LogisticsSupervisionOutput\",\n  \"description\": \"Esquema para el registro de decisiones y análisis de riesgo logístico.\",\n  \"type\": \"object\",\n  \"required\": [\n    \"ID\",\n    \"Ciudad\",\n    \"Acción\",\n    \"Estado final\",\n    \"Timestamp\"\n  ],\n  \"properties\": {\n    \"ID\": {\n      \"type\": \"integer\",\n      \"description\": \"Identificador único de la entrega.\"\n    },\n    \"Ciudad\": {\n      \"type\": \"string\",\n      \"description\": \"Nombre de la ciudad o zona de destino.\"\n    },\n    \"Riesgo Clima (%)\": {\n      \"oneOf\": [\n        { \"type\": \"number\", \"minimum\": 0, \"maximum\": 100 },\n        { \"type\": \"string\", \"description\": \"Usado para indicar error o no disponible, e.g., '—'\" },\n        { \"type\": \"null\" }\n      ],\n      \"description\": \"Probabilidad máxima de precipitación detectada.\"\n    },\n    \"Riesgo Tráfico (%)\": {\n      \"oneOf\": [\n        { \"type\": \"number\", \"minimum\": 0, \"maximum\": 100 },\n        { \"type\": \"string\", \"description\": \"Usado para indicar error o no disponible, e.g., '—'\" },\n        { \"type\": \"null\" }\n      ],\n      \"description\": \"Puntaje de tráfico interpretado basado en la API.\"\n    },\n    \"Acción\": {\n      \"type\": \"string\",\n      \"description\": \"Descripción detallada de la acción tomada: notificación, sugerencia de ruta o sin acción.\"\n    },\n    \"Estado final\": {\n      \"type\": \"string\",\n      \"enum\": [\"Normal\", \"Riesgo alto\", \"Revisión prioritaria\"],\n      \"description\": \"Estado final de la entrega tras el análisis o error de sistema.\"\n    },\n    \"Timestamp\": {\n      \"type\": \"string\",\n      \"format\": \"date-time\",\n      \"description\": \"Fecha y hora de la ejecución en formato ISO 8601 o YYYY-MM-DD HH:mm.\"\n    }\n  }\n}",
        "autoFix": true
      },
